# MAYOMI / One-Drop OS environment example

# Aggregator service base URL (used by server proxy)
AGGREGATOR_BASE=http://localhost:8081
AGG_PORT=8081

# Redis connection
REDIS_URL=redis://localhost:6379

# OpenAI
OPENAI_KEY=
OPENAI_MODEL=gpt-4o

# Local LLM
LOCAL_LLM_URL=

# OpenClaw connector
OPENCLAW_URL=
OPENCLAW_KEY=

# Feble5 connector
FEBLE5_URL=
FEBLE5_KEY=

# Admin/API key (optional)
ADMIN_API_KEY=

# Use local LLM by default (true/false)
USE_LOCAL=false
# Copy to .env and fill values
ADMIN_API_KEY=changeme
OPENAI_KEY=
OPENAI_URL=
OPENAI_MODEL=
USE_LOCAL=false
LOCAL_LLM_URL=http://localhost:8000/generate
REDIS_URL=redis://localhost:6379
AGG_PORT=8081
